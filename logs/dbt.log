[0m16:08:23.069267 [debug] [Thread-3 (]: On model.datagrokr.stg_currency_rates: create or replace   view ANALYTICS_DEV.dbt_dev_staging.stg_currency_rates
  
   as (
    -- Staging for Currency Rates
-- Gets the most recent rate per currency using ROW_NUMBER

WITH source AS (
    SELECT * FROM ANALYTICS_DEV.RAW.currency_rates
),

ranked AS (
    SELECT
        UPPER(TRIM(currency_code))          AS currency_code,
        CAST(rate_to_usd AS FLOAT)          AS rate_to_usd,
        effective_date,
        ROW_NUMBER() OVER (
            PARTITION BY currency_code
            ORDER BY effective_date DESC
        )                                   AS rn
    FROM source
)

SELECT
    currency_code,
    rate_to_usd,
    effective_date
FROM ranked
WHERE rn = 1
  )
/* dbt_dev_stg_currency_rates */;
